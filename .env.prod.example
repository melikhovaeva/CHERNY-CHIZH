#######################################
# Django
#######################################
DJANGO_SECRET_KEY=replace_with_strong_secret_key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

#######################################
# PostgreSQL
#######################################
DB_NAME=ch_ch_db
DB_USER=ch_ch_admin
DB_PASSWORD=replace_with_strong_db_password
DB_HOST=postgres
DB_PORT=5432

#######################################
# S3 / MinIO
#######################################
AWS_ACCESS_KEY_ID=replace_with_minio_access_key
AWS_SECRET_ACCESS_KEY=replace_with_minio_secret_key
AWS_STORAGE_BUCKET_NAME=ch-ch-bucket
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_REGION_NAME=us-east-1
# Домен через который браузер обращается к медиа (nginx проксирует /ch-ch-bucket/)
AWS_S3_CUSTOM_DOMAIN=yourdomain.com

#######################################
# Инфраструктура (postgres superuser + minio root)
#######################################
MINIO_ROOT_USER=replace_with_minio_user
MINIO_ROOT_PASSWORD=replace_with_strong_minio_password
# Пароль суперпользователя postgres (используется init-db.sh)
POSTGRES_PASSWORD=replace_with_postgres_superuser_password
