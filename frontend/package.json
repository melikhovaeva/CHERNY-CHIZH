{
  "name": "frontend-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:user": "yarn workspace user-app dev",
    "dev:admin": "yarn workspace admin-app dev",
    "build": "yarn workspaces foreach -Ap run build",
    "lint": "yarn workspaces foreach -Ap run lint",
    "test": "yarn workspaces foreach -Ap run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
